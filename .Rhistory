"Senator Race\n",
"Mark Warner(D): ", round(prop_uss_20_war, 2), "%\n",
"Daniel Gade(R): ", round(prop_uss_20_ga, 2), "%",
sep = "")),
color = "black",    # Strong border for the districts
linewidth = 0.8) +  # Thicker line for the CD boundaries
# Layer 2: Precincts (Just the lines, no color)
geom_sf(data = map_va,
fill = NA,
color = "white",    # Subtle color for precinct lines
linewidth = 0.05,   # Very thin line so it's not cluttered
alpha = 0.4) +      # Semi-transparent
scale_fill_party_c() +
theme_map() +
labs(title = "Election for the state of Virginia in 2020",
subtitle = "Vote percentage of presidential and senator race")
