map_va_in <- ggplot() +
# 1. BOTTOM LAYER: The Precincts (Visual only)
geom_sf(data = map_va,
fill = NA,
color = "white",
linewidth = 0.1,
alpha = 0.5) +
# 2. TOP LAYER: The Districts (The part you actually touch)
geom_sf(data = popu_va_1,
aes(fill = vote_share,
text = paste(
"District: ", cd_2020, "<br>",
"Biden(D): ", round(prop_priz_20_bid, 2), "%<br>",
"Trump(R): ", round(prop_priz_20_tru, 2), "%<br>",
"Warner(D): ", round(prop_uss_20_war, 2), "%",
sep = "")),
color = "black",
linewidth = 0.6,
alpha = 0.7) + # Making this slightly transparent shows the precincts below
scale_fill_party_c() +
theme_map()
# Convert to plotly
p <- ggplotly(map_va_in, tooltip = "text")
# Ensure ONLY the district layer (now Trace 2) handles the hover
p <- p |>
style(hoverinfo = "skip", traces = 1) |>  # Skip the precincts (bottom)
style(hoveron = "fill", traces = 2)       # Force hover on the district fill (top)
p
