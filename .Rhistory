ggplotly(map_va_1, tooltip = "text")
map_va_1 <- map_va |>
ggplot() +
# 1. Draw precinct lines first (thin and gray)
geom_sf(color = "gray80", linewidth = 0.1, fill = NA) +
# 2. Draw districts with a thicker, distinct border (e.g., black or white)
geom_district(aes(group = cd_2020, fill = ndv, denom = ndv + nrv),
color = "black",  # Change this to your preferred border color
lwd = 0.8) +      # Make the district border thicker
scale_fill_party_c() +
theme_map()
ggplotly(map_va_1, tooltip = "text")
map_va |>
ggplot() +
geom_district(aes(group = cd_2020, fill = ndv, denom = ndv + nrv)) +
geom_sf(color = "gray", linewidth = 0.1, alpha = 0.3) +
scale_fill_party_c() +
theme_map()
View(map_va)
