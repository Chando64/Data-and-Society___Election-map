# 1. Define the plot
map_va_in <- ggplot() +
# LAYER 1: The Districts (The "Bottom" layer for color, but with tooltips)
geom_sf(data = popu_va_1,
aes(fill = vote_share,
text = paste(
"District: ", cd_2020, "<br>",  # Use <br> for Plotly line breaks
"<b>Presidential Race</b><br>",
"Biden(D): ", round(prop_priz_20_bid, 2), "%<br>",
"Trump(R): ", round(prop_priz_20_tru, 2), "%<br>",
"<b>Senator Race</b><br>",
"Warner(D): ", round(prop_uss_20_war, 2), "%<br>",
"Gade(R): ", round(prop_uss_20_ga, 2), "%",
sep = "")),
color = "black",
linewidth = 0.5) +
# LAYER 2: The Precincts (The "Top" layer for lines, but we tell Plotly to skip it)
geom_sf(data = map_va,
fill = NA,
color = "white",
linewidth = 0.1,
alpha = 0.3) +
scale_fill_party_c() +
theme_map()
# 2. Convert to plotly
p <- ggplotly(map_va_in, tooltip = "text")
# 3. Force Plotly to ignore the second layer (Precincts)
# This allows the hover to "pass through" the lines to the districts
p <- p |> style(hoverinfo = "skip", traces = 2)
p
# This prints the names of all layers Plotly sees
lapply(p$x$data, function(x) x$name)
p <- ggplotly(map_va_in, tooltip = "text")
# 3. DYNAMICALLY disable hover for any layer missing the 'text' attribute
# This loops through every 'trace' and sets hoverinfo to "none"
# IF that trace doesn't contain our custom text.
for (i in seq_along(p$x$data)) {
if (is.null(p$x$data[[i]]$text)) {
p$x$data[[i]]$hoverinfo <- "none"
}
}
p
